{
  "name": "@colveor/devkit",
  "version": "1.6.0",
  "description": "Shared development toolkit for the Colveor ecosystem.",
  "private": false,
  "license": "MIT",
  "author": "Skyapp Labs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/colveor/devkit.git"
  },
  "bugs": {
    "url": "https://github.com/colveor/devkit/issues"
  },
  "homepage": "https://github.com/colveor/devkit#readme",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2",
  "files": [
    "*.js",
    "*.json",
    ".github",
    ".vscode",
    ".editorconfig",
    ".gitattributes",
    ".gitignore",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "scripts"
  ],
  "exports": {
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./tsconfig.build.json": "./tsconfig.build.json",
    "./tsconfig.test.json": "./tsconfig.test.json",
    "./eslint.config.js": "./eslint.config.js",
    "./prettier.config.js": "./prettier.config.js",
    "./prettier.library.config.js": "./prettier.library.config.js",
    "./jest.config.js": "./jest.config.js",
    "./jest.library.config.js": "./jest.library.config.js",
    "./eslint.library.config.js": "./eslint.library.config.js",
    "./release.config.js": "./release.config.js",
    "./lint-staged.config.js": "./lint-staged.config.js",
    "./pack-local.js": "./scripts/pack-local.js",
    "./init-library.js": "./scripts/init-library.js",
    "./generate-api-docs.js": "./scripts/generate-api-docs.js"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "node -e \"console.log('@colveor/devkit has no TypeScript sources; skipping typecheck.');\"",
    "build": "node -e \"console.log('@colveor/devkit has no build step; skipping build.');\"",
    "test": "node -e \"console.log('@colveor/devkit has no tests; skipping test.');\"",
    "test:ci": "node -e \"console.log('@colveor/devkit has no tests; skipping test:ci.');\"",
    "check": "npm run lint && npm run validate",
    "format": "prettier --check .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "validate": "node scripts/validate-configs.js"
  },
  "dependencies": {
    "@eslint/js": "^9.31.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "lint-staged": "^15.5.2",
    "openapi-to-postmanv2": "^6.2.0",
    "semantic-release": "^24.2.5",
    "typescript-eslint": "^8.37.0"
  },
  "peerDependencies": {
    "@types/jest": ">=29",
    "@types/node": ">=20",
    "eslint": ">=9",
    "jest": ">=30",
    "prettier": ">=3",
    "ts-jest": ">=29",
    "typescript": ">=5.4"
  },
  "peerDependenciesMeta": {
    "@types/jest": {
      "optional": true
    },
    "jest": {
      "optional": true
    },
    "ts-jest": {
      "optional": true
    }
  },
  "devDependencies": {
    "eslint": "^9.31.0",
    "prettier": "^3.6.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "unrs-resolver": "1.11.1"
  }
}
