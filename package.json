{
  "name": "@colveor/devkit",
  "version": "1.0.4",
  "description": "Shared development toolkit for the Colveor ecosystem.",
  "private": false,
  "license": "MIT",
  "author": "Skyapp Labs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/colveor/devkit.git"
  },
  "bugs": {
    "url": "https://github.com/colveor/devkit/issues"
  },
  "homepage": "https://github.com/colveor/devkit#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "*.js",
    "*.json",
    ".github",
    ".husky",
    ".vscode",
    ".editorconfig",
    ".gitattributes",
    ".gitignore",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "scripts"
  ],
  "exports": {
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./tsconfig.build.json": "./tsconfig.build.json",
    "./tsconfig.test.json": "./tsconfig.test.json",
    "./eslint.config.js": "./eslint.config.js",
    "./prettier.config.js": "./prettier.config.js",
    "./jest.config.js": "./jest.config.js",
    "./release.config.js": "./release.config.js",
    "./commitlint.config.js": "./commitlint.config.js",
    "./lint-staged.config.js": "./lint-staged.config.js",
    "./scripts/check-lockfile-sync.js": "./scripts/check-lockfile-sync.js"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lockfile:sync": "npm install --package-lock-only --ignore-scripts --no-audit",
    "lockfile:check": "node scripts/check-lockfile-sync.js",
    "validate": "node scripts/validate-configs.js"
  },
  "dependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.31.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "semantic-release": "^24.2.5",
    "typescript-eslint": "^8.37.0"
  },
  "peerDependencies": {
    "@types/jest": ">=29",
    "@types/node": ">=20",
    "eslint": ">=9",
    "jest": ">=29",
    "prettier": ">=3",
    "ts-jest": ">=29",
    "typescript": ">=5.4"
  },
  "peerDependenciesMeta": {
    "@types/jest": {
      "optional": true
    },
    "jest": {
      "optional": true
    },
    "ts-jest": {
      "optional": true
    }
  },
  "devDependencies": {
    "eslint": "^9.31.0",
    "prettier": "^3.6.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
